# Credentials PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT issuer (pointe vers keycloak dans Docker)
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/plateforme

# JPA
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
