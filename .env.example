# ============================================================
# Fichier d'exemple — copier en .env et adapter les valeurs
# NE PAS committer .env dans git !
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_keycloak_password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT / Keycloak realm ---
# En local Docker : http://keycloak:8080/realms/plateforme
# En production   : https://auth.votredomaine.com/realms/plateforme
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/plateforme

# --- JPA (dev=update | prod=validate) ---
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
